{
  "name": "carrier-performance-scorecard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "db:seed": "tsx scripts/db-seed.ts",
    "readme:verify": "tsx scripts/readme-verify.ts",
    "safety": "npm audit --audit-level=high",
    "precommit:check": "lint-staged",
    "deadcode:check": "knip --no-progress --no-config-hints --include files,dependencies,unlisted,unresolved,binaries",
    "duplicates:check": "jscpd --config .jscpd.json",
    "large-files:check": "tsx scripts/quality/large-file-check.ts",
    "debt:check": "tsx scripts/quality/debt-check.ts",
    "agents:verify": "tsx scripts/quality/agents-verify.ts",
    "naming:check": "tsx scripts/quality/naming-check.ts",
    "complexity:check": "tsx scripts/quality/complexity-check.ts",
    "queries:check": "tsx scripts/quality/query-pattern-check.ts",
    "bundle:check": "tsx scripts/quality/bundle-size-check.ts",
    "build:performance": "tsx scripts/quality/build-performance-check.ts",
    "test:performance": "tsx scripts/quality/test-performance-check.ts",
    "release-notes:check": "tsx scripts/quality/release-notes-check.ts",
    "dependency-age:check": "tsx scripts/quality/dependency-age-policy-check.ts",
    "stale-flags:check": "tsx scripts/quality/stale-feature-flag-check.ts",
    "quality:check": "npm run format:check && npm run deadcode:check && npm run duplicates:check && npm run large-files:check && npm run debt:check && npm run agents:verify && npm run naming:check && npm run complexity:check && npm run queries:check && npm run bundle:check && npm run build:performance && npm run test:performance && npm run release-notes:check && npm run dependency-age:check && npm run stale-flags:check && npm run readme:verify && npm run safety",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "postcss": "8.5.15",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jscpd": "^4.2.4",
    "jsdom": "^26.1.0",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write"
  }
}
